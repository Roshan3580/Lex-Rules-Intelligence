# Database. Defaults to local SQLite. To use Postgres set e.g.
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/rules
DATABASE_URL=sqlite:///./rules.db

# LLM provider (OpenAI-compatible). Leave LLM_API_KEY blank to run in
# deterministic fallback mode (no external calls).
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# CORS origin for the frontend dev server
FRONTEND_ORIGIN=http://localhost:5173

# Where uploaded source documents are stored on disk
UPLOAD_DIR=./uploads
