# Database. Defaults to local SQLite. To use Postgres set e.g.
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/rules
DATABASE_URL=sqlite:///./rules.db

# LLM provider (OpenAI-compatible). Leave LLM_API_KEY blank to run in
# deterministic fallback mode (no external calls).
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# CORS origin for the frontend dev server (Lovable Vite default is 8080)
FRONTEND_ORIGIN=http://localhost:8080

# Where uploaded source documents are stored on disk
UPLOAD_DIR=./uploads

# When true the backend will insert illustrative CA/TX/NY rules on first
# start so the app is demoable from an empty DB. Default is false —
# production starts empty and waits for real ingestion.
DEMO_MODE=false

# --- Hybrid retrieval (Phase 5) ---
# Embedding provider: none | hash | openai
#   hash   = offline deterministic fallback (default, works without keys)
#   openai = OpenAI-compatible /embeddings endpoint
#   none   = disable embeddings entirely (lexical-only retrieval)
EMBEDDING_PROVIDER=hash
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=384

# Vector store backend: numpy (in-process) — pgvector / chroma reserved.
VECTOR_BACKEND=numpy
VECTOR_INDEX_DIR=./.vector_index

# Change monitoring: POST /api/monitor/run reuses ingestion settings
# (LLM, embeddings, DB). No separate env vars.
